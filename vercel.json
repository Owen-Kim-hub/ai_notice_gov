{
  "buildCommand": "npm run build:vercel",
  "outputDirectory": "dist",
  "regions": ["icn1"],
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 60
    },
    "api/extract.js": {
      "maxDuration": 60
    }
  }
}
